# Local development profile (APP_ENV=dev)
# Uses local Neo4j and local Ollama OpenAI-compatible endpoint.

OPENAI_API_KEY=ollama
OPENROUTER_API_KEY=
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
OPENAI_SMALL_MODEL=llama3.2:3b
OPENAI_LARGE_MODEL=llama3.2:3b

NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jforlocal

SLACK_BOT_TOKEN=replace-with-slack-bot-token
SLACK_SIGNING_SECRET=replace-with-slack-signing-secret
GOOGLE_CREDENTIALS_FILE_PATH=./google-service-account.json
INGESTION_API_TOKEN=replace-with-a-long-random-token
