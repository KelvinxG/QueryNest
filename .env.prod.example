# Production profile (APP_ENV=prod)
# Point to managed infrastructure and hosted model provider.

OPENAI_API_KEY=replace-with-provider-api-key
OPENROUTER_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_SMALL_MODEL=openai/gpt-4o-mini
OPENAI_LARGE_MODEL=openai/gpt-4o

NEO4J_URI=neo4j+s://replace-with-your-aura-uri
NEO4J_USER=replace-with-neo4j-user
NEO4J_PASSWORD=replace-with-neo4j-password

SLACK_BOT_TOKEN=replace-with-slack-bot-token
SLACK_SIGNING_SECRET=replace-with-slack-signing-secret
GOOGLE_CREDENTIALS_FILE_PATH=./google-service-account.json
INGESTION_API_TOKEN=replace-with-a-long-random-token
